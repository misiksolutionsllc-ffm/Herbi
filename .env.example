# ───────────────────────────────────────────────
# Herbi — Environment Variables
# Copy to .env.local for local dev. Never commit .env*.
# ───────────────────────────────────────────────

# Public site URL (used for Stripe redirects). No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Supabase ──────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key (server only — never expose to client)
# Used in the Stripe webhook, order router, and admin API routes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# For deploy.sh: Supabase DB password to build the psql connection string.
# SUPABASE_DB_PASSWORD=your-db-password

# ─── Stripe ───────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook signing secret (whsec_...)
# Local dev: run `pnpm stripe:listen` to get a temporary value.
# Production: create endpoint at /api/webhooks/stripe in Stripe dashboard.
STRIPE_WEBHOOK_SECRET=whsec_...
