# ───────────────────────────────────────────────
# Herbi — Environment Variables
# Copy to .env.local for local dev. Never commit .env*.
# ───────────────────────────────────────────────

# Public site URL (used for Stripe redirects). No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Supabase ──────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key (server only — never expose to client)
# Used ONLY in the Stripe webhook route to bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Stripe ────────────────────────────────────
# Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Developers → Webhooks → your endpoint → Signing secret
# For local dev, `stripe listen` prints a whsec_... value.
STRIPE_WEBHOOK_SECRET=whsec_...
